{
  "name": "@apiagex/server",
  "version": "0.6.1",
  "description": "Fastify server package for Apiagex CMS.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "apiagex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/app.js",
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b && node ../../scripts/copy-server-assets.mjs && node ../../scripts/set-bin-permissions.mjs dist/cli.js",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@apiagex/database": "0.6.1",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.8.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0"
  }
}
